# Git Ignore - Streaming Platform
# Prevent secrets and sensitive files from being committed

# ============================================================================
# CERTIFICATES & KEYS (NEVER COMMIT THESE)
# ============================================================================
certs/
security/certs/
security/certs-legacy/
*.pem
*.key
*.csr
*.srl
*.conf

# ============================================================================
# ENVIRONMENT VARIABLES & SECRETS (NEVER COMMIT)
# ============================================================================
.env
.env.local
.env.prod
.env.production.local
.env.*.local

# Keep the .env.dev template (no secrets):
!.env.dev

# ============================================================================
# DEVELOPMENT & BUILD ARTIFACTS
# ============================================================================
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
*.log
*.tmp

# ============================================================================
# DOCKER & COMPOSE
# ============================================================================
docker-compose.override.yml
.docker/

# ============================================================================
# GO BUILD ARTIFACTS
# ============================================================================
*.o
*.a
*.so
go.sum

# ============================================================================
# DATA & RECORDINGS
# ============================================================================
go_ingest/local_recordings/
go_ingest/recordings/
go_processing/buffers/
postgres_data/
redis_data/

# ============================================================================
# BACKUPS
# ============================================================================
*.sql
*.tar.gz
/backups/
/backup_*/

# ============================================================================
# IDE & EDITOR
# ============================================================================
.vscode/*
!.vscode/settings.json
.idea/*
*.swp
*.swo
*~
