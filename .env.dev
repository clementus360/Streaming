# ============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# ============================================================================
# Use this for local testing with docker-compose
# For production, copy to .env.prod and update values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=stream_db
DATABASE_DSN=postgres://user:password@postgres:5432/stream_db?sslmode=disable

# ============================================================================
# CACHE CONFIGURATION (Redis)
# ============================================================================
REDIS_ADDR=redis:6379

# ============================================================================
# DISTRIBUTION OBJECT STORAGE (OPTIONAL)
# ============================================================================
R2_ENABLED=true
R2_ACCOUNT_ID=b57ea61fecd5c2e59521688b7fac8c95
R2_ACCESS_KEY_ID=ca877fd5606937e5a9f712de9309fa39
R2_SECRET_ACCESS_KEY=833038bd037b8b6a905907bc6cf02d8e45d0b9ca34527f3e262f127623a0d0cf
R2_BUCKET=live-stream
R2_PUBLIC_BASE_URL=https://media.ishimwe.dev
R2_KEY_PREFIX=hls
R2_UPLOAD_TIMEOUT=4s
# When true, playlists are rewritten to absolute CDN/R2 URLs for media segments.
R2_REDIRECT_SEGMENTS=true

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=dev_jwt_secret_32_character_minimum_key
RESEND_KEY=dev_resend_key
SENDER_EMAIL=noreply@localhost
BASE_URL=http://localhost:8081

# ============================================================================
# PROCESSING SERVICE CONFIGURATION
# ============================================================================
FFMPEG_PATH=/usr/bin/ffmpeg
PROCESSING_DISABLE_1080P=true
TLS_SERVER_NAME=localhost
GRPC_AUTHORITY_OVERRIDE=

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
METRICS_PORT=18081
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
